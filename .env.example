WALLET_ADDRESS=           # Your USDC-receiving wallet address on Base (0x...)
PORT=3000
NODE_ENV=production

# Network: eip155:84532 = Base Sepolia (testnet, works with default x402.org facilitator)
#          eip155:8453  = Base Mainnet (requires custom facilitator URL)
NETWORK=eip155:84532

# Optional: custom facilitator URL (defaults to https://x402.org/facilitator)
# FACILITATOR_URL=https://your-facilitator.example.com

# Coinbase CDP facilitator for Base Mainnet (https://api.cdp.coinbase.com/platform/v2/x402)
# When both are set, CDP facilitator is used automatically (FACILITATOR_URL is ignored).
# Get your API key at https://portal.cdp.coinbase.com/
# CDP_API_KEY_ID=your-key-id
# CDP_API_KEY_SECRET=your-base64-private-key
